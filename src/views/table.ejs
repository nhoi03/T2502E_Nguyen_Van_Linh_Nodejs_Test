<div class="card">
                <h5 class="card-header">Striped rows</h5>
                <div class="table-responsive text-nowrap">
                  <table class="table table-striped">
                    <thead>
                      <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Image</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                    <% if (trees && trees.length > 0) { %>
                        <% trees.forEach(tree => { %>
                        <tr>
                            <td>
                            
                            <span><%= tree.treename %></span>
                            </td>

                            <td>
                            <%= tree.description ? tree.description.substring(0, 50) : 'No description' %>
                            </td>

                            <td>
                            <% if (tree.image) { %>
                                <img src="<%= tree.image %>" 
                                    alt="tree" 
                                    style="width:40px;height:40px;border-radius:50%;">
                            <% } else { %>
                                No Image
                            <% } %>
                            </td>

                            <td>
                            <span class="badge bg-label-success">Active</span>
                            </td>

                            <td>
                            <div class="dropdown">
                                <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                <i class="ri-more-2-line"></i>
                                </button>

                                <div class="dropdown-menu">
                                <a class="dropdown-item"
                                    href="#"
                                    onclick="openEditModal('<%= tree._id %>', '<%= tree.treename %>', '<%= tree.description %>', '<%= tree.image %>')">
                                    <i class="ri-pencil-line me-1"></i> Edit
                                </a>

                                <form action="/delete/<%= tree._id %>" method="POST" style="display:inline;">
                                    <button onclick="return confirm('Delete?')">
                                    <i class="ri-delete-bin-6-line me-1"></i> Delete
                                </button>
                                </form>
                                </div>
                            </div>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                        <td colspan="5" class="text-center">No trees found</td>
                        </tr>
                    <% } %>
                    </tbody>
                  </table>
                  <div class="modal fade" id="editModal" tabindex="-1">
                    <div class="modal-dialog">
                        <form id="editForm" method="POST">
                        <div class="modal-content">

                            <div class="modal-header">
                            <h5 class="modal-title">Edit Tree</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body">

                            <div class="mb-3">
                                <label>Name</label>
                                <input type="text" name="treename" id="editName" class="form-control" required>
                            </div>

                            <div class="mb-3">
                                <label>Description</label>
                                <input type="text" name="description" id="editDesc" class="form-control">
                            </div>

                            <div class="mb-3">
                                <label>Image URL</label>
                                <input type="text" name="image" id="editImg" class="form-control">
                            </div>

                            </div>

                            <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Save</button>
                            </div>

                        </div>
                        </form>
                    </div>
                    </div>
                </div>
              </div>
<script>
function openEditModal(id, name, description, image) {
  document.getElementById('editName').value = name;
  document.getElementById('editDesc').value = description;
  document.getElementById('editImg').value = image;

  document.getElementById('editForm').action = '/edit/' + id;

  var modal = new bootstrap.Modal(document.getElementById('editModal'));
  modal.show();
}
</script>